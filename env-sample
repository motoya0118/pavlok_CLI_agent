# ===== 認証情報 =====
PAVLOK_API_KEY={YOUR_API_KEY} # Pavlok APIキー
PAVLOK_API_BASE=https://api.pavlok.com/api/v5 # Pavlok APIベースURL（通常は変更不要）
SLACK_BOT_USER_OAUTH_TOKEN={YOUR_API_KEY} # Slack Bot User OAuth Token

# ===== Slack 設定 =====
SLACK_CHANNEL={CHANNEL} # 通知を送るSlackチャンネル名またはID
SLACK_SIGNING_SECRET={YOUR_SIGNING_SECRET} # Slack署名検証用シークレット
DEFAULT_USER_ID={your_user_id} # デフォルトのSlackユーザーID（ユーザー特定に使用）

# ===== 内部API保護 =====
ONI_INTERNAL_SECRET={YOUR_INTERNAL_SECRET} # /internal/* エンドポイント保護用シークレット

# ===== 時刻・タイムアウト設定 =====
TIMEOUT_REMIND=600 # リマインド応答タイムアウト（秒）
TIMEOUT_REVIEW=600 # 振り返り応答タイムアウト（秒）
RETRY_DELAY=5 # エラー後リトライの待機時間（分）

# ===== Pavlok 罰設定 =====
PAVLOK_TYPE_PUNISH=zap # 罰のPavlokモード（beep/vibe/zap など）
PAVLOK_VALUE_PUNISH=35 # 罰のPavlok強度
PAVLOK_TYPE_NOTION=vibe # 通知時のPavlokモード（beep/vibe/zap）
PAVLOK_VALUE_NOTION=35 # 通知時のPavlok強度（0-100）

# ===== 安全上限・制限 =====
LIMIT_DAY_PAVLOK_COUNTS=100 # 1日に実行できるPavlok回数の上限
LIMIT_PAVLOK_ZAP_VALUE=100 # zap強度の上限
